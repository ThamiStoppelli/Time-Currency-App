{
  "expo": {
    "name": "TimeCurrencyApp",
    "slug": "TimeCurrencyApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo-icon.png",
    "scheme": "timecurrencyapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#705ADF"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#705ADF"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.thamiresstoppelli.timecurrencyapp"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/logo-icon.png",
      "name": "Time Currency",
      "shortName": "TimeCurrency",
      "themeColor": "#705ADF",
      "backgroundColor": "#705ADF"
    },
    "extra": {
      "eas": {
        "projectId": "ffe5a7df-2fd7-42ca-9264-eab00046d38e"
      }
    },
    "plugins": [
      "expo-web-browser"
    ]
  }
}
